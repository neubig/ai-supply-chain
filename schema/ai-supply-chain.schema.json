{
  "$ref": "#/definitions/SupplyChainGraph",
  "definitions": {
    "SupplyChainGraph": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "0.1.0",
          "default": "0.1.0"
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z]+:[a-z0-9][a-z0-9_.-]*$"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "application",
                  "model",
                  "dataset",
                  "software",
                  "benchmark",
                  "organization",
                  "license",
                  "infrastructure"
                ]
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "canonicalUrl": {
                "type": "string",
                "format": "uri",
                "pattern": "^https?:\\/\\/"
              },
              "homepageUrl": {
                "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/canonicalUrl"
              },
              "repositoryUrl": {
                "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/canonicalUrl"
              },
              "license": {
                "type": "object",
                "properties": {
                  "expression": {
                    "type": "string",
                    "minLength": 1
                  },
                  "url": {
                    "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/canonicalUrl"
                  },
                  "openness": {
                    "type": "string",
                    "enum": [
                      "open_source",
                      "open_core",
                      "open_weights",
                      "source_available",
                      "proprietary",
                      "unknown"
                    ]
                  },
                  "osiApproved": {
                    "type": [
                      "boolean",
                      "null"
                    ]
                  },
                  "notes": {
                    "type": "string",
                    "minLength": 1
                  },
                  "sourceIds": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^[a-z0-9][a-z0-9:_./-]*$"
                    },
                    "minItems": 1
                  }
                },
                "required": [
                  "expression",
                  "openness",
                  "sourceIds"
                ],
                "additionalProperties": false
              },
              "openness": {
                "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/license/properties/openness",
                "default": "unknown"
              },
              "tasks": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "default": []
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "default": []
              },
              "sources": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/license/properties/sourceIds/items"
                    },
                    "type": {
                      "type": "string",
                      "enum": [
                        "github_repo",
                        "github_license",
                        "huggingface_model_card",
                        "huggingface_dataset_card",
                        "package_registry",
                        "official_docs",
                        "official_website",
                        "paper",
                        "benchmark_definition",
                        "api_response",
                        "web_search",
                        "manual_entry"
                      ]
                    },
                    "title": {
                      "type": "string",
                      "minLength": 1
                    },
                    "url": {
                      "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/canonicalUrl"
                    },
                    "quote": {
                      "type": "string",
                      "minLength": 1
                    },
                    "note": {
                      "type": "string",
                      "minLength": 1
                    },
                    "published_date": {
                      "type": "string",
                      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                    },
                    "retrieved_date": {
                      "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/sources/items/properties/published_date"
                    },
                    "publisher": {
                      "type": "string",
                      "minLength": 1
                    },
                    "collectionMethod": {
                      "type": "string",
                      "enum": [
                        "github_api",
                        "huggingface_api",
                        "package_registry_api",
                        "official_api",
                        "static_document",
                        "paper_metadata",
                        "benchmark_scrape",
                        "manual_review",
                        "web_search"
                      ]
                    },
                    "confidence": {
                      "type": "string",
                      "enum": [
                        "high",
                        "medium",
                        "low"
                      ],
                      "default": "medium"
                    }
                  },
                  "required": [
                    "id",
                    "type",
                    "title",
                    "url",
                    "collectionMethod"
                  ],
                  "additionalProperties": false
                },
                "minItems": 1
              },
              "metrics": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/license/properties/sourceIds/items"
                    },
                    "category": {
                      "type": "string",
                      "enum": [
                        "adoption",
                        "benchmark",
                        "cost",
                        "maintenance",
                        "openness",
                        "provenance",
                        "risk",
                        "security",
                        "velocity",
                        "performance",
                        "usage",
                        "quality"
                      ]
                    },
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "value": {
                      "type": [
                        "number",
                        "string",
                        "boolean"
                      ]
                    },
                    "unit": {
                      "type": "string",
                      "minLength": 1
                    },
                    "task": {
                      "type": "string",
                      "minLength": 1
                    },
                    "benchmarkId": {
                      "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/id"
                    },
                    "measuredAt": {
                      "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/sources/items/properties/published_date"
                    },
                    "higherIsBetter": {
                      "type": "boolean"
                    },
                    "sourceIds": {
                      "type": "array",
                      "items": {
                        "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/license/properties/sourceIds/items"
                      },
                      "minItems": 1
                    },
                    "notes": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "id",
                    "category",
                    "name",
                    "value",
                    "sourceIds"
                  ],
                  "additionalProperties": false
                },
                "default": []
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "enum": [
                        "sbom",
                        "ai_sbom",
                        "slsa",
                        "openssf_scorecard",
                        "signature",
                        "vulnerability_scan",
                        "model_card",
                        "dataset_card",
                        "benchmark_card",
                        "license_review"
                      ]
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "present",
                        "partial",
                        "missing",
                        "unknown",
                        "not_applicable"
                      ]
                    },
                    "score": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 100
                    },
                    "url": {
                      "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/canonicalUrl"
                    },
                    "checkedAt": {
                      "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/sources/items/properties/published_date"
                    },
                    "sourceIds": {
                      "type": "array",
                      "items": {
                        "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/license/properties/sourceIds/items"
                      },
                      "minItems": 1
                    },
                    "notes": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "kind",
                    "status",
                    "sourceIds"
                  ],
                  "additionalProperties": false
                },
                "default": []
              },
              "updatePolicy": {
                "type": "object",
                "properties": {
                  "refreshMethod": {
                    "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/sources/items/properties/collectionMethod"
                  },
                  "cadence": {
                    "type": "string",
                    "enum": [
                      "daily",
                      "weekly",
                      "monthly",
                      "quarterly",
                      "manual"
                    ],
                    "default": "monthly"
                  },
                  "deterministic": {
                    "type": "boolean",
                    "default": true
                  },
                  "instructions": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "refreshMethod",
                  "instructions"
                ],
                "additionalProperties": false
              },
              "metadata": {
                "type": "object",
                "additionalProperties": {},
                "default": {}
              }
            },
            "required": [
              "id",
              "kind",
              "name",
              "description",
              "sources",
              "updatePolicy"
            ],
            "additionalProperties": false
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^edge:[a-z0-9][a-z0-9_.:-]*$"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "supports",
                  "depends_on",
                  "requires",
                  "trained_on",
                  "trained_with",
                  "evaluated_on",
                  "developed_by",
                  "hosted_by",
                  "licensed_as",
                  "derived_from",
                  "uses_data",
                  "implements",
                  "runs_on",
                  "optimized_for",
                  "supports_hardware",
                  "sandboxed_by"
                ]
              },
              "source": {
                "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/id"
              },
              "target": {
                "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/id"
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "confidence": {
                "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/sources/items/properties/confidence",
                "default": "medium"
              },
              "validFrom": {
                "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/sources/items/properties/published_date"
              },
              "validUntil": {
                "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/sources/items/properties/published_date"
              },
              "sources": {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/sources/items"
                },
                "minItems": 1
              },
              "metrics": {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/SupplyChainGraph/properties/nodes/items/properties/metrics/items"
                },
                "default": []
              },
              "metadata": {
                "type": "object",
                "additionalProperties": {},
                "default": {}
              }
            },
            "required": [
              "id",
              "kind",
              "source",
              "target",
              "description",
              "sources"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "nodes",
        "edges"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
